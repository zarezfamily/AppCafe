rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Foro: imágenes de hilos subidas por usuarios autenticados.
    match /foro_hilos/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Resto: bloquear por defecto.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
