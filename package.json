{
  "name": "etiove",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "private": true,
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "web:build": "node web/build-pages.js",
    "web:deploy": "npm run web:build && cd web && npx wrangler pages deploy . --project-name etiove --branch preview --no-bundle --commit-dirty=true",
    "web:deploy:prod": "npm run web:build && cd web && npx wrangler pages deploy . --project-name etiove --no-bundle --commit-dirty=true",
    "env:check:seed-auth": "node --env-file=.env scripts/check_env.js seed-auth",
    "env:check:seed-api": "node --env-file=.env scripts/check_env.js seed-api",
    "env:check:import-dry": "node --env-file=.env scripts/check_env.js import-dry",
    "env:check:import-write": "node --env-file=.env scripts/check_env.js import-write",
    "seed:5": "npm run env:check:seed-auth && node --env-file=.env seed5.js",
    "seed:10": "npm run env:check:seed-auth && node --env-file=.env seed10.js",
    "seed:full": "npm run env:check:seed-api && node --env-file=.env seed_cafes_v2.js",
    "cafes:delete": "npm run env:check:seed-api && node --env-file=.env delete_cafes.js",
    "screenshots:ios": "./scripts/capture_screenshots_ios.sh",
    "screenshots:ios:auto": "AUTO_CAPTURE=1 ./scripts/capture_screenshots_ios.sh",
    "import:es:coffee:dry": "npm run env:check:import-dry && DRY_RUN=true node --env-file=.env scripts/import_top_es_real.js",
    "import:es:coffee": "npm run env:check:import-write && node --env-file=.env scripts/import_top_es_real.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check .",
    "validate": "npm run format:check && npm run lint",
    "prepare": "husky"
  },
  "dependencies": {
    "@expo-google-fonts/playfair-display": "^0.4.2",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/native-stack": "^7.14.10",
    "expo": "~54.0.33",
    "expo-av": "~16.0.8",
    "expo-camera": "~17.0.10",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-local-authentication": "~17.0.8",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.16",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "node-fetch": "^2.7.0",
    "openfoodfacts-nodejs": "^0.1.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-purchases": "^9.15.1",
    "react-native-safe-area-context": "~5.6.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@eslint/js": "^9.25.1",
    "@types/react": "~19.1.10",
    "eslint": "^9.25.1",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.2"
  },
  "lint-staged": {
    "*.{js,jsx,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{js,jsx}": [
      "eslint --fix"
    ]
  }
}
