// ════════════════════════════════════════════════════════════════
//  REGLAS DE SEGURIDAD DE FIRESTORE — Graino ☕
//  Copia esto en: Firebase Console → Firestore → Reglas
// ════════════════════════════════════════════════════════════════
//
//  IMPORTANTE: estas reglas usan Firebase Auth para identificar
//  al usuario mediante el campo `request.auth.uid`.
//  Como usamos Firebase Auth REST (no el SDK), el token JWT
//  que devuelve loginUser/registerUser se debe pasar en las
//  cabeceras de cada petición para que las reglas funcionen.
//
//  Para aplicarlas con la API REST, añade a cada fetch:
//    headers: {
//      'Content-Type': 'application/json',
//      'Authorization': `Bearer ${user.token}`,   // ← token de Firebase Auth
//    }
//
//  Actualiza tu firebaseConfig.js para incluir ese header.
// ════════════════════════════════════════════════════════════════

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Colección "cafes" ──────────────────────────────────────
    // Cada café tiene un campo "uid" con el UID del propietario.
    // Solo el propietario puede leer, editar o borrar sus cafés.
    match /cafes/{cafeId} {
      allow read:   if request.auth != null
                    && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null
                    && resource.data.uid == request.auth.uid;
    }

    // ── Colección "ranking" ────────────────────────────────────
    // El ranking es público para lectura (cualquiera puede ver).
    // Solo usuarios autenticados pueden votar (crear/actualizar).
    match /ranking/{rankId} {
      allow read:   if true;
      allow write:  if request.auth != null;
    }
  }
}
