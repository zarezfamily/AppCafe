rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function hasString(field, min, max) {
      return request.resource.data[field] is string
        && request.resource.data[field].size() >= min
        && request.resource.data[field].size() <= max;
    }

    function isValidThreadAccess(data) {
      return data.accessLevel == null
        || (data.accessLevel is string
          && (data.accessLevel == 'public' || data.accessLevel == 'registered_only'));
    }

    function canReadThreadData(data) {
      return isSignedIn() || data.accessLevel == null || data.accessLevel == 'public';
    }

    function canReadThreadById(threadId) {
      return exists(/databases/$(database)/documents/foro_hilos/$(threadId))
        && canReadThreadData(get(/databases/$(database)/documents/foro_hilos/$(threadId)).data);
    }

    function isThreadAuthor(threadId) {
      return exists(/databases/$(database)/documents/foro_hilos/$(threadId))
        && get(/databases/$(database)/documents/foro_hilos/$(threadId)).data.authorUid == request.auth.uid;
    }

    function isNonNegativeInt(value) {
      return value is int && value >= 0;
    }

    function isThreadCountersUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'upvotes',
          'voterUids',
          'replyCount',
          'reportedCount',
          'reporterUids'
        ])
        && request.resource.data.voterUids is string
        && isNonNegativeInt(request.resource.data.upvotes)
        && (!('reporterUids' in request.resource.data) || request.resource.data.reporterUids is string)
        && (!('replyCount' in request.resource.data) || isNonNegativeInt(request.resource.data.replyCount))
        && (!('reportedCount' in request.resource.data) || isNonNegativeInt(request.resource.data.reportedCount));
    }

    function isReplyCountersUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'upvotes',
          'voterUids',
          'reportedCount',
          'reporterUids'
        ])
        && request.resource.data.voterUids is string
        && isNonNegativeInt(request.resource.data.upvotes)
        && (!('reporterUids' in request.resource.data) || request.resource.data.reporterUids is string)
        && (!('reportedCount' in request.resource.data) || isNonNegativeInt(request.resource.data.reportedCount));
    }

      function isBlogCommentVotesUpdate() {
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'upvotes',
          'downvotes',
          'upvoterUids',
          'downvoterUids'
        ])
        && isNonNegativeInt(request.resource.data.upvotes)
        && (!('downvotes' in request.resource.data) || isNonNegativeInt(request.resource.data.downvotes))
        && (!('upvoterUids' in request.resource.data) || request.resource.data.upvoterUids is string)
        && (!('downvoterUids' in request.resource.data) || request.resource.data.downvoterUids is string);
      }

    function isValidPremiumPlan(value) {
      return value is string && (value == 'monthly' || value == 'lifetime');
    }

    function isValidPremiumRecord(data) {
      return data.uid is string
        && data.uid == request.auth.uid
        && isValidPremiumPlan(data.plan)
        && data.activatedAt is string
        && data.updatedAt is string
        && data.transactionId is string
        && (data.expiresAt == null || data.expiresAt is string)
        && (!('provider' in data) || data.provider is string)
        && (!('productId' in data) || data.productId is string);
    }

    function isValidUserProfile(data, uid) {
      return data.uid is string
        && data.uid == uid
        && data.uid == request.auth.uid
        && (!('displayName' in data) || (data.displayName is string && data.displayName.size() >= 1 && data.displayName.size() <= 80))
        && (!('avatarUrl' in data) || (data.avatarUrl is string && data.avatarUrl.size() <= 2000))
        && (!('motto' in data) || (data.motto is string && data.motto.size() <= 280))
        && (!('updatedAt' in data) || data.updatedAt is string)
        && (!('createdAt' in data) || data.createdAt is string);
    }

    // Catálogo de cafés: público lectura, escritura autenticada.
    match /cafes/{cafeId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.uid is string
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isSignedIn();
    }

    match /ranking/{rankId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Foro: hilos públicos para lectura. El filtrado de 'registered_only' lo hace el cliente.
    match /foro_hilos/{threadId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.authorUid == request.auth.uid
        && hasString('title', 3, 120)
        && hasString('body', 3, 1000)
        && request.resource.data.categoryId is string
        && request.resource.data.categoryLabel is string
        && isValidThreadAccess(request.resource.data);
      allow update: if isSignedIn()
        && (
          (
            resource.data.authorUid == request.auth.uid
            && request.resource.data.authorUid == resource.data.authorUid
            && isValidThreadAccess(request.resource.data)
          )
          || isThreadCountersUpdate()
        );
      allow delete: if isSignedIn() && resource.data.authorUid == request.auth.uid;
    }

    match /foro_respuestas/{replyId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.authorUid == request.auth.uid
        && hasString('threadId', 1, 200)
        && hasString('body', 1, 1000)
        && canReadThreadById(request.resource.data.threadId);
      allow update: if isSignedIn()
        && (
          (
            resource.data.authorUid == request.auth.uid
            && request.resource.data.authorUid == resource.data.authorUid
          )
          || isReplyCountersUpdate()
        );
      allow delete: if isSignedIn()
        && (
          resource.data.authorUid == request.auth.uid
          || isThreadAuthor(resource.data.threadId)
        );
    }

    match /blog_comentarios/{commentId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.authorUid is string
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.authorName is string
        && hasString('postSlug', 1, 200)
        && hasString('body', 3, 1000)
        && request.resource.data.createdAt is string;
      allow update: if isSignedIn()
        && (
          (resource.data.authorUid == request.auth.uid)
          || isBlogCommentVotesUpdate()
        );
      allow delete: if isSignedIn() && resource.data.authorUid == request.auth.uid;
    }

    match /user_profiles/{userId} {
      allow read: if true;
      allow create, update: if isSignedIn() && isValidUserProfile(request.resource.data, userId);
      allow delete: if false;
    }

    match /profile_follows/{followId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.followerUid is string
        && request.resource.data.followerUid == request.auth.uid
        && request.resource.data.targetUid is string
        && request.resource.data.targetUid.size() > 0
        && request.resource.data.targetUid != request.auth.uid
        && (!('createdAt' in request.resource.data) || request.resource.data.createdAt is string);
      allow update: if false;
      allow delete: if isSignedIn() && resource.data.followerUid == request.auth.uid;
    }

    match /direct_messages/{messageId} {
      allow create: if isSignedIn()
        && request.resource.data.senderUid is string
        && request.resource.data.senderUid == request.auth.uid
        && request.resource.data.recipientUid is string
        && request.resource.data.recipientUid.size() > 0
        && hasString('body', 2, 2000)
        && request.resource.data.createdAt is string;
      allow read: if isSignedIn()
        && (
          resource.data.senderUid == request.auth.uid
          || resource.data.recipientUid == request.auth.uid
        );
      allow update, delete: if false;
    }

    match /newsletter_subscribers/{subscriberId} {
      allow read: if isSignedIn() && subscriberId == request.auth.uid;
      allow create, update: if isSignedIn()
        && subscriberId == request.auth.uid
        && request.resource.data.uid is string
        && request.resource.data.uid == request.auth.uid
        && hasString('email', 5, 200)
        && request.resource.data.subscribed is bool;
      allow delete: if false;
    }

    match /push_subscriptions/{subscriberId} {
      allow read: if isSignedIn() && subscriberId == request.auth.uid;
      allow create, update: if isSignedIn()
        && subscriberId == request.auth.uid
        && request.resource.data.uid is string
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.expoPushToken is string
        && request.resource.data.notificationsEnabled is bool;
      allow delete: if isSignedIn() && subscriberId == request.auth.uid;
    }

    match /premium_users/{premiumUserId} {
      allow read: if isSignedIn() && premiumUserId == request.auth.uid;
      allow create, update: if isSignedIn()
        && premiumUserId == request.auth.uid
        && isValidPremiumRecord(request.resource.data);
      allow delete: if false;
    }

    // Diario de catas: privado (solo el usuario ve el suyo)
    match /diario_catas/{cataId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }
  }
}
